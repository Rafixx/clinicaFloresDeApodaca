---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
const legalBase = lang === "en" ? "/en/info-legal" : "/info-legal";
---

<footer class="bg-zeniaMarronOscuro text-zeniaBlanco/75 mt-20">
  <div class="container mx-auto lg:max-w-4xl md:max-w-2xl px-6 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10">

      <div>
        <p class="text-zeniaBlanco font-semibold text-base mb-3 tracking-wide">
          Clínica Flores de Apodaca
        </p>
        <p class="text-sm leading-relaxed text-zeniaBlanco/50">
          C/Patricio Ferrándiz, 86<br />
          03700 Dénia, Alicante
        </p>
      </div>

      <div>
        <h6 class="text-xs font-bold uppercase tracking-widest text-zeniaRosaOscuro mb-4">
          {t("footer.legal")}
        </h6>
        <ul class="space-y-2 text-sm">
          <li>
            <a href={`${legalBase}#politica`} class="hover:text-zeniaRosaOscuro transition-colors duration-200">
              {t("footer.privacy")}
            </a>
          </li>
          <li>
            <a href={`${legalBase}#aviso`} class="hover:text-zeniaRosaOscuro transition-colors duration-200">
              {t("footer.legal_notice")}
            </a>
          </li>
          <li>
            <a href={`${legalBase}#condiciones`} class="hover:text-zeniaRosaOscuro transition-colors duration-200">
              {t("footer.terms")}
            </a>
          </li>
          <li>
            <a href={`${legalBase}#cookies`} class="hover:text-zeniaRosaOscuro transition-colors duration-200">
              {t("footer.cookies")}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h6 class="text-xs font-bold uppercase tracking-widest text-zeniaRosaOscuro mb-4">
          {t("footer.contact")}
        </h6>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="tel:663274378" class="hover:text-zeniaRosaOscuro transition-colors duration-200">
              663 27 43 78
            </a>
          </li>
          <li>
            <a href="mailto:info@clinicafloresdeapodaca.com" class="hover:text-zeniaRosaOscuro transition-colors duration-200 break-all">
              info@clinicafloresdeapodaca.com
            </a>
          </li>
        </ul>
      </div>

    </div>

    <div class="border-t border-zeniaBlanco/10 mt-10 pt-6 text-xs text-zeniaBlanco/35 text-center">
      © {currentYear} Clínica Flores de Apodaca. {t("footer.copyright")}
    </div>
  </div>
</footer>
