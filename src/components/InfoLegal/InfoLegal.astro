          )}
        </div>
      ))}
    </div>
  </section>

  <section id="cookies" class="scroll-mt-28">
    <h2 class="text-2xl lg:text-3xl font-bold text-center pt-4 pb-2 text-zeniaMarronOscuro">{c.cookieTitle}</h2>
    <div class="text-[15px] leading-relaxed text-zeniaMarronOscuro/80 space-y-5 mt-8 max-w-3xl mx-auto border-l-2 border-zeniaRosaOscuro/20 pl-6">
      <p>{c.cookieIntro}</p>
      {c.cookieSections.map((s: {title: string; text: string}) => (
        <div>
          <p class="font-semibold text-zeniaMarronOscuro">{s.title}</p>
          <p set:html={s.text} />
        </div>
      ))}
    </div>
  </section>
</div>
