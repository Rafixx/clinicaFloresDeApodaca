const c = content[lang as keyof typeof content] || content.es;
---

<h1 class="text-3xl lg:text-5xl font-bold text-center py-16 text-zeniaMarronOscuro">
  {c.title}
</h1>

<div class="text-lg leading-relaxed text-zeniaMarronOscuro space-y-4 mb-12">
  <p set:html={c.intro} />

  <div>
    <p class="font-semibold text-zeniaMarronOscuro mb-2">{c.treatmentsTitle}</p>
    <ul class="list-none space-y-1 pl-4">
      {c.treatments.map((t) => (
        <li set:html={`• ${t}`} />
      ))}
    </ul>
  </div>

  <div>
    <p class="font-semibold text-zeniaMarronOscuro mb-2">{c.benefitsTitle}</p>
    <ul class="list-none space-y-1 pl-4">
      {c.benefits.map((b) => (
        <li set:html={`• ${b}`} />
      ))}
    </ul>
  </div>

  <div>
    <p class="font-semibold text-zeniaMarronOscuro mb-2">{c.whyTitle}</p>
    <p set:html={c.why1} />
    <p set:html={c.why2} />
  </div>

  <div>
    <p class="font-semibold text-zeniaMarronOscuro mb-2">{c.trainingTitle}</p>
    <p set:html={c.training1} />
    <p class="font-semibold text-zeniaRosaOscuro">{c.cta}</p>
  </div>
</div>
