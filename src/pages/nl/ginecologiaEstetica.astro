---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/Home/SectionContainer.astro";
import SectionFullX from "@/components/Home/SectionFullX.astro";
import GinecologiaEsteticaContent from "@/components/Tratamientos/Ginecologia/GinecologiaEstetica.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

type tLang = (str: any) => any;
const lang = getLangFromUrl(Astro.url);
const t: tLang = useTranslations(lang);
---

<Layout title={t("layout.title")} description={t("layout.description")}>
  <main>
    <SectionFullX id="home" class="pt-16 md:pt-24">
      <img
        src="/tratamientos/categorias/ginecologia-estetica.webp"
        alt="Ginecología Estética en Clínica Flores de Apodaca"
        class="w-full h-auto object-cover"
      />
    </SectionFullX>
    <SectionContainer class="py-16 md:py-24">
      <GinecologiaEsteticaContent lang={lang} />
    </SectionContainer>
  </main>
</Layout>
